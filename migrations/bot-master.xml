<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
    logicalFilePath="file:./migrations/bot-master.xml">

    <changeSet id="bot-001-create-processed-kafka-messages" author="vlad">
        <createTable tableName="processed_kafka_messages">
            <column name="topic" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <column name="partition_id" type="int">
                <constraints nullable="false"/>
            </column>

            <column name="offset_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="message_key" type="text"/>

            <column name="processed_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="processed_kafka_messages"
            columnNames="topic, partition_id, offset_id"
            constraintName="pk_processed_kafka_messages"/>
    </changeSet>

</databaseChangeLog>
